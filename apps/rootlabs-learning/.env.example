# Rootlabs Learning App — Environment Variables
# Copy this file to .env.local and fill in real values when company API access lands.
# All variables are OPTIONAL — the app runs fully on mock implementations without any of these set.

# ============================================================
# Shopify (for products, auth, checkout)
# ============================================================
EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN=
EXPO_PUBLIC_SHOPIFY_STOREFRONT_API_TOKEN=

# ============================================================
# Anthropic Claude (for AI coach)
# ============================================================
# Note: never commit a real key. Use a server proxy in production.
EXPO_PUBLIC_CLAUDE_API_PROXY_URL=

# ============================================================
# PostHog (for analytics)
# ============================================================
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# Sentry (for crash reporting — optional)
# ============================================================
EXPO_PUBLIC_SENTRY_DSN=
