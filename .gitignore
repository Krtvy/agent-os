# User research artifacts — out of Observer scope
research/

# Competitor content pipeline outputs (deliverables tracked at repo root)
# Track structure + deliverables; ignore the raw/analyzed JSON dumps which grow large
competitor_content/raw/**/*.json
competitor_content/analyzed/**/*.json
competitor_content/raw/.last-discovery

# Per-agent log directories (rotate constantly, regenerated each run)
logs/**/*.log
logs/**/*.json
!logs/**/.gitkeep

# Observer runtime logs (regenerated each run)
.claude/agents/_meta/observer/run.log
.claude/agents/_meta/conductor/run.log
.claude/agents/_meta/observer/.run.lock

# OS noise
.DS_Store
*.swp

# Backups created during preflight remediation
*.bak

# Bundle tarball — extracted, kept locally only
observer-ecosystem.tar.gz

# Credentials pool — REAL keys/cookies/tokens. Never commit.
# The template (.credentials.example.yml) IS committed so the schema is reproducible.
.credentials.yml
.credentials.local.yml
.env
.env.local

# Browser cookie dumps captured for Kalodata sessions
*.cookies.txt
cookies/

# Rolling session-end snapshot — overwritten each session, not historical record
_audit/.last-session.md

# Design reference assets (iPhone screenshots, certification PDFs) — bulky, not source
ui-data/

# Imported zip archives — may carry credentials, never commit either the zip
# or the extracted contents
*.zip
_private/
excel_automation/
daily_reporting/

# Installer DMGs — never commit binary installers
*.dmg

# Hackathon media — large binary video/audio files (keep deck + images)
hackathonkit/videos/
hackathonkit/audio/
hackathonkit/final/
hackathonkit/pinky-01.mp3

# Portal data uploads — raw spreadsheets, not source
portal/*.xlsx
portal/*.csv

# POC runtime cache — regenerated by the app, not config
pocs/**/cache.json
pocs/**/dashboard_cache_*.json
pocs/**/deliverables/
pocs/**::p=*/
