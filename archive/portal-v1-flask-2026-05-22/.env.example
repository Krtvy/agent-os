# portal/.env.example — copy to .env on VPS, fill values. DO NOT COMMIT .env.
# Generate FLASK_SECRET_KEY with: python -c 'import secrets; print(secrets.token_urlsafe(32))'

FLASK_SECRET_KEY=
FLASK_ENV=production

# ===== Local-dev shortcuts (set both to skip OAuth entirely) =====
# DEV_BYPASS_AUTH=1 disables Google login; every request is treated as DEV_USER_EMAIL.
# NEVER set this in production — anyone hitting the portal becomes "logged in".
# Override per-request with ?as=<email> to test per-POC behavior.
DEV_BYPASS_AUTH=0
DEV_USER_EMAIL=kartavya@mosaicwellness.in
# =================================================================

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
# Leave blank when DEV_BYPASS_AUTH=1.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Domain restriction — only emails ending with this domain may log in
ALLOWED_EMAIL_DOMAIN=mosaicwellness.in

# Anthropic API key (Yudhi's brain, called via `claude --print`)
ANTHROPIC_API_KEY=

# Supabase creds — read by lib/yudhi-sql.sh; pointer to existing .env
SUPABASE_ENV_FILE=/Users/mosaic/projects/observer-test/_private/daily_reporting/.env

# Paths inside the repo (absolute)
REPO_ROOT=/Users/mosaic/projects/observer-test
DELIVERABLES_ROOT=/Users/mosaic/projects/observer-test/pocs
CANDIDATES_DIR=/Users/mosaic/projects/observer-test/training/patterns/_candidates

# Headless Yudhi invocation
CLAUDE_BIN=claude
YUDHI_TIMEOUT_SECONDS=90

# Portal hostname — used by Caddy for auto-SSL.
# Pick whichever domain you own and have a DNS A record for.
PORTAL_DOMAIN=portal.example.com

# Optional: SMTP for completion-email notifications.
# If SMTP_HOST is unset, the email notify step is silently skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
